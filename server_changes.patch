+
+
+// ── Toplu SMS Ayarları ──
+model GlobalSettings {
+  id                 String   @id @default("global")
+  smsContractUrl     String?
+  smsContractExampleUrl String?
+  smsExampleDocUrl   String?
+  whatsappNumber     String?  @default("905392647655")
+  updatedAt          DateTime @updatedAt
+}
+
+
+// ═══════════════════════════════════════
+// STK Chat Models (shared DB sync)
+// ═══════════════════════════════════════
+model STKChatMessage {
+  id          String   @id @default(cuid())
+  stkId       String
+  userId      String
+  message     String   @db.Text
+  isDeleted   Boolean  @default(false)
+  createdAt   DateTime @default(now())
+
+  stk         STKOrganization @relation(fields: [stkId], references: [id], onDelete: Cascade)
+  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
+  reports     STKChatReport[]
+  reactions   STKChatReaction[]
+
+  @@index([stkId, createdAt])
+}
+
+model STKChatReport {
+  id               String   @id @default(cuid())
+  messageId        String
+  reportedByUserId String
+  reason           String
+  status           String   @default("PENDING")
+  createdAt        DateTime @default(now())
+
+  message          STKChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
+  reportedByUser   User           @relation(fields: [reportedByUserId], references: [id], onDelete: Cascade)
+
+  @@index([messageId])
+  @@index([status])
+}
+
+model STKChatReaction {
+  id        String   @id @default(cuid())
+  messageId String
+  userId    String
+  type      String
+  createdAt DateTime @default(now())
+
+  message   STKChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
+  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
+
+  @@unique([messageId, userId])
+  @@index([messageId])
+}
