  targetAudience  String          @default("ALL_MEMBERS")
  targetFilters   Json?
  status          String          @default("SENT")
  scheduledAt     DateTime?
  sentAt          DateTime?
  recipientCount  Int             @default(0)
  deliveredCount  Int             @default(0)
  failedCount     Int             @default(0)
  createdById     String
  isBlocked       Boolean         @default(false)
  blockedReason   String?
  blockedAt       DateTime?
  blockedById     String?
  channel         String?
  smsCost         Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())
  User            User            @relation(fields: [createdById], references: [id], onUpdate: NoAction)
  STKOrganization STKOrganization @relation(fields: [stkId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([channel])
  @@index([status])
  @@index([stkId])
}

