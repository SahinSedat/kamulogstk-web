generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                @id @default(cuid())
  email                     String?               @unique
  phone                     String?               @unique
  password                  String
  name                      String?
  firstName                 String?
  lastName                  String?
  avatarUrl                 String?
  role                      Role                  @default(USER)
  isVerified                Boolean               @default(false)
  isActive                  Boolean               @default(true)
  subscriptionTier          String?               @default("basic")
  employmentType            String?
  ministryCode              Int?
  title                     String?
  credits                   Int                   @default(0)
  isPremium                 Boolean               @default(false)
  premiumUntil              DateTime?
  aiTokens                  Int                   @default(0)
  becayisListingLimit       Int?
  listingQuotaOneTime       Int                   @default(0)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  address                   String?
  city                      String?
  cvApplicationsUsed        Int                   @default(0)
  cvChatTokens              Int                   @default(20)
  district                  String?
  emailChangeCode           String?
  newEmail                  String?
  phoneNumber               String?               @unique
  taxNumber                 String?
  taxOffice                 String?
  verificationCode          String?
  verificationExpires       DateTime?
  emailVerified             DateTime?
  accountDeleted            Boolean               @default(false)
  accountDeletedAt          DateTime?
  accountFrozen             Boolean               @default(false)
  institutionName           String?
  kvkkAccepted              Boolean               @default(false)
  lastEmailChangeDate       DateTime?
  lastLoginMethod           String?
  lastPhoneChangeDate       DateTime?
  phoneVerified             Boolean               @default(false)
  postalCode                String?
  userAgreementAccepted     Boolean               @default(false)
  tcKimlik                  String?
  yearsWorking              Int?
  istihdamTuru              String?
  unvan                     String?
  isAriyor                  Boolean?              @default(false)
  isOnline                  Boolean               @default(false)
  lastSeen                  DateTime?
  isWorkInfoGeneratedByAI   Boolean               @default(false)
  aiGeneratedBecayisText    String?
  atamaUsulu                String?
  bakanlik                  String?
  isLookingForBecayis       Boolean               @default(false)
  kurum                     String?
  targetCities              String?
  aiExtractedEmploymentType String?
  alternativeCities         String?
  fcmToken                  String?
  subInstitutionId          String?
  isRadarActive             Boolean               @default(false)
  radarActivatedAt          DateTime?
  radarExpiresAt            DateTime?
  notifEmail                Boolean               @default(true)
  notifPush                 Boolean               @default(true)
  notifSms                  Boolean               @default(false)
  notifWhatsapp             Boolean               @default(true)
  careerAiTokens            Int                   @default(0)
  careerPremiumUntil        DateTime?
  isCareerPremium           Boolean               @default(false)
  careerRadarExpiresAt      DateTime?
  isCareerRadarActive       Boolean               @default(false)
  deactivatedAt             DateTime?
  deactivationReason        String?
  isDeactivated             Boolean               @default(false)
  consultantJetons          Int                   @default(0)
  banBecayisUntil           DateTime?
  banForumUntil             DateTime?
  banReason                 String?
  managedBranchId           String?
  status                    String                @default("ACTIVE")
  occupation                String?
  workplace                 String?
  education                 String?
  preferredCity             String?
  notifSystem               Boolean               @default(true)
  gender                    String?
  birthDate                 DateTime?
  registrationPurpose       String?
  isStkOfficial             Boolean               @default(false)
  stkOfficialRole           String?
  isStkMember               Boolean               @default(false)
  memberStkName             String?
  avatar                    String?
  lastLoginAt               DateTime?
  managedStkId              String?
  otpCode                   String?
  otpExpiry                 DateTime?
  aiUsageLogs               AIUsageLog[]
  adminLogs                 AdminLog[]
  approvedListings          BecayisListing[]      @relation("ApprovedListings")
  becayisListings           BecayisListing[]      @relation("OwnerListings")
  receivedBecayisMessages   BecayisMessage[]      @relation("ReceivedBecayisMessages")
  sentBecayisMessages       BecayisMessage[]      @relation("SentBecayisMessages")
  blockedMe                 BlockedUser[]         @relation("BlockedByUser")
  blockedByMe               BlockedUser[]         @relation("BlockerUser")
  cvs                       CV[]
  cvanalyses                CVAnalysis[]
  chatSessions              ChatSession[]
  consultationRequests      ConsultationRequest[]
  conversations             Conversation[]
  favoriteAds               FavoriteAd[]
  kariyerChatRooms          KariyerChatRoom[]
  kariyerSubscription       KariyerSubscription?
  kpssExamHistory           KpssExamHistory[]
  kpssQuestionReports       KpssQuestionReport[]
  receivedMatchRequests     MatchRequest[]        @relation("ReceivedMatchRequests")
  sentMatchRequests         MatchRequest[]        @relation("SentMatchRequests")
  Member                    Member[]
  sentMessages              Message[]
  MessageCampaign           MessageCampaign[]
  notifications             Notification[]
  orders                    Order[]
  reports                   Report[]              @relation("UserReports")
  stkAuditLogs              STKAuditLog[]
  chatMessages              STKChatMessage[]
  chatReactions             STKChatReaction[]
  chatReports               STKChatReport[]
  managedSTK                STKOrganization?  @relation("STKManager")
  salesRecords              SalesRecord[]
  storeTransactions         StoreTransaction[]
  subscriptions             Subscription[]
  usageRecords              UsageRecord[]
  STKBranch                 STKBranch?            @relation(fields: [managedBranchId], references: [id])

  @@index([managedBranchId])
  @@index([status])
}

model Institution {
  id              String           @id @default(cuid())
  name            String           @unique
  isActive        Boolean          @default(true)
  order           Int              @default(0)
  createdAt       DateTime         @default(now())
  listings        BecayisListing[]
  subInstitutions SubInstitution[]
}

model SubInstitution {
  id            String      @id @default(cuid())
  name          String
  institutionId String
  createdAt     DateTime    @default(now())
  isApproved    Boolean     @default(false)
  institution   Institution @relation(fields: [institutionId], references: [id])

  @@unique([name, institutionId])
  @@index([institutionId])
}

model BecayisListing {
  id                     String           @id @default(cuid())
  ownerId                String
  title                  String
  role                   String           @default("memur")
  institutionId          String?
  branch                 String           @default("")
  currentCity            String
  targetCity             String
  assignmentMethod       String?
  description            String
  isPremium              Boolean          @default(false)
  premiumUntil           DateTime?
  status                 String           @default("draft")
  approvedById           String?
  slug                   String           @unique
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  adNumber               String?          @unique
  pendingChanges         Json?
  viewCount              Int              @default(0)
  isGeneratedByKamulogAI Boolean          @default(false)
  atamaUsulu             String?
  bakanlik               String?
  istihdamTuru           String?
  kurum                  String?
  unvan                  String?
  boostedUntil           DateTime?
  hasUsedFreeBoost       Boolean          @default(false)
  isUrgent               Boolean          @default(false)
  rejectionReason        String?
  removalReason          String?
  urgentUntil            DateTime?
  expiresAt              DateTime?
  isExpiredNotified      Boolean          @default(false)
  isExpiringNotified     Boolean          @default(false)
  approvedAt             DateTime?
  approvedBy             User?            @relation("ApprovedListings", fields: [approvedById], references: [id])
  institution            Institution?     @relation(fields: [institutionId], references: [id])
  owner                  User             @relation("OwnerListings", fields: [ownerId], references: [id])
  messages               BecayisMessage[]
  favoriteAds            FavoriteAd[]
  matchRequests          MatchRequest[]   @relation("MatchRequestsForListing")
  reports                Report[]
}

model MatchRequest {
  id             String           @id @default(cuid())
  senderId       String
  receiverId     String
  listingId      String
  status         MatchStatus      @default(PENDING)
  messageType    MatchMessageType
  messageText    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  receiverHidden Boolean          @default(false)
  senderHidden   Boolean          @default(false)
  listing        BecayisListing   @relation("MatchRequestsForListing", fields: [listingId], references: [id], onDelete: Cascade)
  receiver       User             @relation("ReceivedMatchRequests", fields: [receiverId], references: [id])
  sender         User             @relation("SentMatchRequests", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([listingId, senderId])
}

model BecayisMessage {
  id              String         @id @default(cuid())
  senderId        String
  receiverId      String
  listingId       String
  content         String
  isRead          Boolean        @default(false)
  createdAt       DateTime       @default(now())
  isFiltered      Boolean        @default(false)
  status          MessageStatus  @default(SENT)
  isDeletedByUser Boolean        @default(false)
  listing         BecayisListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  receiver        User           @relation("ReceivedBecayisMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender          User           @relation("SentBecayisMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, listingId])
  @@index([receiverId, isRead])
  @@index([receiverId, status])
  @@index([listingId])
}

model FavoriteAd {
  id        String         @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime       @default(now())
  listing   BecayisListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model Consultant {
  id                      String             @id @default(cuid())
  userId                  String?            @unique
  name                    String
  title                   String
  category                String
  bio                     String
  specializations         String[]
  experienceYears         Int                @default(0)
  avatarUrl               String?
  rating                  Float              @default(0)
  reviewCount             Int                @default(0)
  isOnline                Boolean            @default(false)
  isFeatured              Boolean            @default(false)
  completedConsultations  Int                @default(0)
  isActive                Boolean            @default(true)
  createdAt               DateTime           @default(now())
  consultantCredits       Int                @default(0)
  creditPrice             Float              @default(0)
  iban                    String?
  sessionFeeJeton         Int                @default(5)
  email                   String?
  phone                   String?
  workingHours            String             @default("Hafta içi 09:00 - 17:00")
  costPerMessage          Int                @default(5)
  maxMessagesPerSession   Int                @default(10)
  commissionRate          Float              @default(20)
  payouts                 ConsultantPayout[]
  consultantConversations Conversation[]
  payoutRequests          PayoutRequest[]
  reviews                 Review[]
  packages                ServicePackage[]
}

model ServicePackage {
  id           String     @id @default(cuid())
  consultantId String
  name         String
  price        Float
  description  String
  durationMins Int
  includes     String[]
  iapProductId String?
  isActive     Boolean    @default(true)
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String     @id @default(cuid())
  userId        String
  consultantId  String
  category      String
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int        @default(0)
  createdAt     DateTime   @default(now())
  isEnded       Boolean    @default(false)
  consultant    Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id])
  messages      Message[]
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  type           MessageType   @default(TEXT)
  fileUrl        String?
  fileName       String?
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now())
  isFiltered     Boolean       @default(false)
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User          @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([status])
}

model Review {
  id             String     @id @default(cuid())
  consultantId   String
  userId         String
  userName       String
  rating         Float
  comment        String
  createdAt      DateTime   @default(now())
  conversationId String?    @unique
  consultant     Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
}

model Order {
  id            String            @id @default(cuid())
  userId        String
  status        String            @default("COMPLETED")
  createdAt     DateTime          @default(now())
  amount        Float             @default(0)
  invoiceStatus String            @default("UNSENT")
  notes         String?
  orderNumber   String            @unique
  planId        String?
  updatedAt     DateTime          @updatedAt
  orderType     String            @default("SUBSCRIPTION")
  plan          SubscriptionPlan? @relation(fields: [planId], references: [id])
  user          User              @relation(fields: [userId], references: [id])

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([orderType])
}

model ConsultationRequest {
  id           String   @id @default(cuid())
  userId       String
  consultantId String
  packageId    String
  description  String
  aiBriefing   String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model SubscriptionPlan {
  id                 String         @id @default(cuid())
  name               String
  interval           String         @default("monthly")
  price              Float
  description        String?
  badgeText          String?
  yearlyDiscountRate Int            @default(20)
  includedQuota      Int            @default(5)
  isActive           Boolean        @default(true)
  order              Int            @default(0)
  createdAt          DateTime       @default(now())
  appleProductId     String?
  entitlements       String[]       @default([])
  features           String[]       @default([])
  googleProductId    String?
  aiSearchQuota      Int            @default(15)
  boostQuota         Int            @default(1)
  listingQuota       Int            @default(1)
  matchRequestQuota  Int            @default(15)
  isDefault          Boolean        @default(false)
  boostDurationDays  Int            @default(7)
  urgentDurationDays Int            @default(7)
  urgentQuota        Int            @default(0)
  hasRadarFeature    Boolean        @default(false)
  radarDurationDays  Int            @default(30)
  yearlyPrice        Float          @default(0)
  isUnlimited        Boolean        @default(false)
  tisChatQuota       Int            @default(0)
  orders             Order[]
  subscriptions      Subscription[]
}

model Subscription {
  id            String           @id @default(cuid())
  userId        String
  planId        String
  status        String           @default("active")
  startedAt     DateTime         @default(now())
  endsAt        DateTime
  createdAt     DateTime         @default(now())
  productId     String?
  purchaseToken String?
  store         String?
  plan          SubscriptionPlan @relation(fields: [planId], references: [id])
  user          User             @relation(fields: [userId], references: [id])
}

model Report {
  id           String         @id @default(cuid())
  reporterId   String
  reportedAdId String
  reason       String
  status       String         @default("pending")
  createdAt    DateTime       @default(now())
  reportedAd   BecayisListing @relation(fields: [reportedAdId], references: [id], onDelete: Cascade)
  reporter     User           @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedAdId])
  @@index([status])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
}

model SalesRecord {
  id               String   @id @default(cuid())
  orderNumber      String   @unique
  userId           String
  subscriptionId   String?
  plan             String
  amount           Float
  currency         String   @default("TRY")
  paymentMethod    String?
  status           String   @default("COMPLETED")
  notes            String?
  billingName      String?
  billingEmail     String?
  billingPhone     String?
  billingAddress   String?
  billingCity      String?
  billingDistrict  String?
  billingTaxNumber String?
  billingTaxOffice String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model KariyerSubscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  plan      String    @default("FREE")
  status    String    @default("PENDING")
  orderCode String?   @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CV {
  id             String       @id @default(cuid())
  userId         String
  title          String
  data           String
  template       String       @default("modern")
  pdfPath        String?
  pdfGeneratedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses       CVAnalysis[]
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  type      String
  count     Int      @default(1)
  month     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, month])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  messages  String
  cvId      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobListing {
  id             String        @id @default(cuid())
  code           String?       @unique
  title          String
  company        String
  location       String?
  description    String
  requirements   String?
  type           String        @default("PRIVATE")
  sourceUrl      String?
  applicationUrl String?
  salary         String?
  deadline       DateTime?
  employerPhone  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isActive       Boolean       @default(true)
  analyses       CVAnalysis[]
  favoriteJobs   FavoriteJob[]

  @@index([code])
}

model FavoriteJob {
  id        String     @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime   @default(now())
  job       JobListing @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

model CVAnalysis {
  id        String     @id @default(cuid())
  userId    String
  cvId      String
  jobId     String
  score     Int
  feedback  String
  createdAt DateTime   @default(now())
  cv        CV         @relation(fields: [cvId], references: [id], onDelete: Cascade)
  job       JobListing @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String?
  discountType    String    @default("PERCENT")
  discountValue   Float
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  maxUsage        Int?
  usageCount      Int       @default(0)
  planRestriction String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

model KariyerConsultant {
  id          String                    @id @default(cuid())
  name        String
  phone       String
  title       String
  description String?
  avatarUrl   String?
  isActive    Boolean                   @default(true)
  userId      String?                   @unique
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  chatRooms   KariyerChatRoom[]
  ratings     KariyerConsultantRating[]
}

model KariyerChatRoom {
  id           String                   @id @default(cuid())
  userId       String
  consultantId String
  status       String                   @default("ACTIVE")
  closedAt     DateTime?
  closedBy     String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  messages     KariyerChatMessage[]
  consultant   KariyerConsultant        @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating       KariyerConsultantRating?

  @@unique([userId, consultantId])
  @@index([userId])
  @@index([consultantId])
  @@index([status])
}

model KariyerChatMessage {
  id         String          @id @default(cuid())
  roomId     String
  senderId   String
  senderType String
  content    String
  isRead     Boolean         @default(false)
  createdAt  DateTime        @default(now())
  room       KariyerChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([createdAt])
}

model KariyerConsultantRating {
  id           String            @id @default(cuid())
  roomId       String            @unique
  consultantId String
  userId       String
  rating       Int
  comment      String?
  createdAt    DateTime          @default(now())
  consultant   KariyerConsultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  room         KariyerChatRoom   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([consultantId])
  @@index([userId])
}

model MediaCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  media     Media[]
}

model Media {
  id         String         @id @default(cuid())
  filename   String
  url        String
  mimeType   String?
  size       Int?
  categoryId String?
  link       String?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  category   MediaCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([createdAt])
  @@index([isActive])
}

model WhatsAppLog {
  id           String   @id @default(cuid())
  phoneNumber  String
  message      String
  messageType  String   @default("VERIFICATION")
  status       String   @default("SENT")
  userId       String?
  userEmail    String?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([phoneNumber])
  @@index([messageType])
  @@index([status])
  @@index([createdAt])
}

model CookieConsent {
  id          String   @id @default(cuid())
  ipAddress   String
  userAgent   String?
  userId      String?
  consentType String   @default("all")
  acceptedAt  DateTime @default(now())
  expiresAt   DateTime

  @@index([ipAddress])
  @@index([userId])
  @@index([acceptedAt])
}

model TISDocument {
  id          String   @id @default(cuid())
  institution String
  role        String   @default("")
  title       String
  description String   @default("")
  fileUrl     String
  fileName    String
  fileSize    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([institution])
  @@index([role])
}

model TISFile {
  id          String   @id @default(cuid())
  role        String   @default("")
  title       String
  description String   @default("")
  fileUrl     String
  fileName    String
  fileSize    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([role])
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  summary   String?
  category  String
  imageUrl  String?
  status    String   @default("draft")
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ConsultantApplication {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  category        String
  specialization  String?
  bio             String?
