"use client";

import { useState, useEffect, useCallback } from "react";
import { Settings, Database, Shield, Globe, Bell, Save, Check, Loader2, Smartphone } from "lucide-react";

// Ayar key'leri ve varsayılan değerleri
const SETTING_KEYS = {
  defaultCredits: { key: "DEFAULT_WELCOME_CREDITS", default: "2", label: "Yeni Üyelik Varsayılan Jetonu", type: "number", section: "limits", desc: "Kayıt olan kullanıcıya otomatik verilen jeton" },
  premiumAiQuota: { key: "PREMIUM_AI_QUOTA", default: "5", label: "Premium Aylık AI İlan Kotası", type: "number", section: "limits", desc: "Premium kullanıcının aylık AI ilan oluşturma hakkı" },
  becayisListingCost: { key: "becayis_listing_cost", default: "10", label: "İlan Yayınlama Jeton Ücreti", type: "number", section: "limits", desc: "İlan yayınlamak için gereken jeton" },
  maxListingPerUser: { key: "MAX_LISTING_PER_USER", default: "3", label: "Kullanıcı Başına İlan Limiti", type: "number", section: "limits", desc: "Ücretsiz kullanıcı max ilan sayısı" },
  premiumListingLimit: { key: "PREMIUM_LISTING_LIMIT", default: "10", label: "Premium İlan Limiti", type: "number", section: "limits", desc: "Premium kullanıcı max ilan sayısı" },
  siteName: { key: "SITE_NAME", default: "Kamulog", label: "Site Adı", type: "text", section: "general", desc: "" },
  siteUrl: { key: "SITE_URL", default: "https://kamulog.net", label: "Site URL", type: "text", section: "general", desc: "" },
  supportEmail: { key: "SUPPORT_EMAIL", default: "destek@kamulog.net", label: "Destek E-posta", type: "text", section: "general", desc: "" },
  maintenanceMode: { key: "MAINTENANCE_MODE", default: "false", label: "Bakım Modu", type: "toggle", section: "toggles", desc: "Aktifken yalnızca admin erişebilir" },
  autoApproveListings: { key: "AUTO_APPROVE_LISTINGS", default: "false", label: "İlanları Otomatik Onayla", type: "toggle", section: "toggles", desc: "Yeni ilanlar onay beklemeden yayınlanır" },
  emailNotifications: { key: "EMAIL_NOTIFICATIONS", default: "true", label: "E-posta Bildirimleri", type: "toggle", section: "toggles", desc: "Kullanıcılara e-posta bildirimi gönder" },
  pushNotifications: { key: "PUSH_NOTIFICATIONS", default: "true", label: "Push Bildirimleri", type: "toggle", section: "toggles", desc: "Mobil push notification gönder" },
  // ─── Mobil Uygulama Özellikleri ───────────────────────
  onboardingActive: { key: "ONBOARDING_ACTIVE", default: "false", label: "Onboarding (Karşılama)", type: "toggle", section: "mobile", desc: "Uygulama ilk açılışında karşılama slider'ı göster" },
  storyActive: { key: "STORY_ACTIVE", default: "false", label: "Story Özelliği", type: "toggle", section: "mobile", desc: "Anasayfada Instagram-stil hikaye çubuğunu göster" },
  tutorialActive: { key: "TUTORIAL_ACTIVE", default: "false", label: "Uygulama İçi Eğitim", type: "toggle", section: "mobile", desc: "İlk girişte önemli alanları aydınlatarak tanıt" },
  onboardingVersion: { key: "ONBOARDING_VERSION", default: "1", label: "Onboarding Versiyonu", type: "number", section: "mobile_num", desc: "Değiştiğinde onboarding tüm kullanıcılara tekrar gösterilir" },
  // ─── İletişim Bilgileri ───────────────────────────
  contactEmail: { key: "CONTACT_EMAIL", default: "", label: "İletişim E-posta", type: "text", section: "contact", desc: "Mobil uygulamada görüntülenecek iletişim e-postası" },
  contactPhone: { key: "CONTACT_PHONE", default: "", label: "İletişim Telefon", type: "text", section: "contact", desc: "Mobil uygulamada görüntülenecek telefon numarası" },
  contactWhatsApp: { key: "CONTACT_WHATSAPP", default: "", label: "WhatsApp Numarası", type: "text", section: "contact", desc: "Mobil uygulamada WhatsApp iletişim numarası (ör: 905392647655)" },
};

export default function SettingsPage() {
  const [saved, setSaved] = useState(false);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [settings, setSettings] = useState<Record<string, string>>({});

  const loadSettings = useCallback(async () => {
    try {
      const res = await fetch("/api/admin/settings");
      const data = await res.json();
      const map: Record<string, string> = {};
      for (const def of Object.values(SETTING_KEYS)) {
        map[def.key] = def.default;
      }
      if (data.settingsMap) {
        for (const [key, value] of Object.entries(data.settingsMap)) {
          map[key] = value as string;
        }
      } else if (Array.isArray(data.settings)) {
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        for (const item of data.settings as any[]) {
          map[item.key] = item.value;
        }
      }
      setSettings(map);
    } catch (e) {
      console.error("Ayarlar yüklenemedi:", e);
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => { loadSettings(); }, [loadSettings]);

  const handleSave = async () => {
    setSaving(true);
    try {
      const settingsArray = Object.values(SETTING_KEYS).map((def) => ({
        key: def.key,
        value: settings[def.key] ?? def.default,
      }));
      const res = await fetch("/api/admin/settings", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ settings: settingsArray }),
      });
      if (res.ok) {
        setSaved(true);
        setTimeout(() => setSaved(false), 2000);
      }
    } catch (e) {
      console.error("Ayarlar kaydedilemedi:", e);
    } finally {
      setSaving(false);
    }
  };

  const updateSetting = (key: string, value: string) => {
    setSettings((prev) => ({ ...prev, [key]: value }));
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center py-20">
        <Loader2 className="w-8 h-8 animate-spin" style={{ color: "var(--primary)" }} />
      </div>
    );
  }

  const generalSettings = Object.values(SETTING_KEYS).filter((v) => v.section === "general");
  const limitSettings = Object.values(SETTING_KEYS).filter((v) => v.section === "limits");
  const toggleSettings = Object.values(SETTING_KEYS).filter((v) => v.section === "toggles");
  const mobileToggles = Object.values(SETTING_KEYS).filter((v) => v.section === "mobile");
  const mobileNumSettings = Object.values(SETTING_KEYS).filter((v) => v.section === "mobile_num");
  const contactSettings = Object.values(SETTING_KEYS).filter((v) => v.section === "contact");

  return (
    <div className="space-y-6 max-w-4xl">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-2xl font-bold flex items-center gap-2"><Settings className="w-6 h-6 text-text-secondary" /> Sistem Ayarları</h2>
          <p className="text-text-secondary text-sm mt-1">Tüm ayarlar veritabanında (SystemSetting) saklanır</p>
        </div>
        <button onClick={handleSave} disabled={saving}
          className="flex items-center gap-2 px-4 py-2.5 rounded-xl gradient-primary text-white text-sm font-medium hover:opacity-90 transition-all glow-primary disabled:opacity-50">
          {saving ? <><Loader2 className="w-4 h-4 animate-spin" /> Kaydediliyor...</> : saved ? <><Check className="w-4 h-4" /> Kaydedildi!</> : <><Save className="w-4 h-4" /> Kaydet</>}
        </button>
      </div>

      {/* Limits — En önemli ayarlar */}
      <div className="glass-card p-6" style={{ border: "1px solid rgba(var(--primary-rgb, 56,189,248), 0.2)" }}>
        <h3 className="text-lg font-semibold mb-4 flex items-center gap-2"><Database className="w-5 h-5 text-cyan-400" /> Jeton & Kota Ayarları</h3>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
          {limitSettings.map((def) => (
            <div key={def.key} className="p-4 rounded-xl bg-white/[0.03] border border-white/5">
              <label className="text-xs font-semibold" style={{ color: "var(--text-secondary)" }}>{def.label}</label>
              <input
                type="number"
                value={settings[def.key] || "0"}
                onChange={(e) => updateSetting(def.key, e.target.value)}
                className="w-full text-lg font-bold mt-2 px-3 py-2 rounded-lg"
                style={{ background: "var(--bg-muted)", color: "var(--text)", border: "1px solid var(--border)" }}
              />
              {def.desc && <p className="text-[11px] mt-1.5" style={{ color: "var(--text-muted)" }}>{def.desc}</p>}
            </div>
          ))}
        </div>
      </div>

      {/* General */}
      <div className="glass-card p-6">
        <h3 className="text-lg font-semibold mb-4 flex items-center gap-2"><Globe className="w-5 h-5 text-primary" /> Genel Ayarlar</h3>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          {generalSettings.map((def) => (
            <div key={def.key}><label className="text-xs text-text-muted">{def.label}</label>
              <input value={settings[def.key] || ""} onChange={(e) => updateSetting(def.key, e.target.value)}
                className="w-full text-sm mt-1 px-3 py-2 rounded-lg"
                style={{ background: "var(--bg-muted)", color: "var(--text)", border: "1px solid var(--border)" }}
              /></div>
          ))}
        </div>
      </div>

      {/* Toggles */}
      <div className="glass-card p-6">
        <h3 className="text-lg font-semibold mb-4 flex items-center gap-2"><Shield className="w-5 h-5 text-red-400" /> Güvenlik & Kontrol</h3>
        <div className="space-y-4">
          {toggleSettings.map((def) => {
            const enabled = settings[def.key] === "true";
            const icons: Record<string, React.ElementType> = {
              MAINTENANCE_MODE: Shield,
              AUTO_APPROVE_LISTINGS: Check,
              EMAIL_NOTIFICATIONS: Bell,
              PUSH_NOTIFICATIONS: Bell,
              ONBOARDING_ACTIVE: Smartphone,
              STORY_ACTIVE: Smartphone,
              TUTORIAL_ACTIVE: Smartphone,
            };
            const Icon = icons[def.key] || Settings;
            return (
              <div key={def.key} className="flex items-center justify-between p-3 rounded-xl bg-white/[0.03]">
                <div className="flex items-center gap-3">
                  <Icon className="w-5 h-5" style={{ color: "var(--text-muted)" }} />
                  <div>
                    <p className="text-sm font-medium">{def.label}</p>
                    <p className="text-xs text-text-muted">{def.desc}</p>
                  </div>
                </div>
                <button
                  onClick={() => updateSetting(def.key, enabled ? "false" : "true")}
                  className={`relative w-12 h-6 rounded-full transition-colors ${enabled ? "bg-primary" : "bg-gray-300"}`}
                >
                  <div className={`absolute top-0.5 w-5 h-5 rounded-full bg-white shadow-md transition-transform ${enabled ? "left-[26px]" : "left-0.5"}`} />
                </button>
              </div>
            );
          })}
        </div>
      </div>

      {/* Mobil Uygulama Özellikleri */}
      <div className="glass-card p-6" style={{ border: "1px solid rgba(var(--primary-rgb, 56,189,248), 0.15)" }}>
        <h3 className="text-lg font-semibold mb-4 flex items-center gap-2"><Smartphone className="w-5 h-5 text-emerald-400" /> Mobil Uygulama Özellikleri</h3>
        <div className="space-y-4">
          {mobileToggles.map((def) => {
            const enabled = settings[def.key] === "true";
            return (
              <div key={def.key} className="flex items-center justify-between p-3 rounded-xl bg-white/[0.03]">
                <div className="flex items-center gap-3">
                  <Smartphone className="w-5 h-5" style={{ color: "var(--text-muted)" }} />
                  <div>
                    <p className="text-sm font-medium">{def.label}</p>
                    <p className="text-xs text-text-muted">{def.desc}</p>
                  </div>
                </div>
                <button
                  onClick={() => updateSetting(def.key, enabled ? "false" : "true")}
                  className={`relative w-12 h-6 rounded-full transition-colors ${enabled ? "bg-emerald-500" : "bg-gray-300"}`}
                >
                  <div className={`absolute top-0.5 w-5 h-5 rounded-full bg-white shadow-md transition-transform ${enabled ? "left-[26px]" : "left-0.5"}`} />
                </button>
              </div>
            );
          })}
          {mobileNumSettings.map((def) => (
            <div key={def.key} className="p-3 rounded-xl bg-white/[0.03]">
              <label className="text-xs font-semibold" style={{ color: "var(--text-secondary)" }}>{def.label}</label>
              <input
                type="number"
                value={settings[def.key] || def.default}
                onChange={(e) => updateSetting(def.key, e.target.value)}
                className="w-full text-sm mt-2 px-3 py-2 rounded-lg"
                style={{ background: "var(--bg-muted)", color: "var(--text)", border: "1px solid var(--border)" }}
              />
              {def.desc && <p className="text-[11px] mt-1.5" style={{ color: "var(--text-muted)" }}>{def.desc}</p>}
            </div>
          ))}
        </div>
      </div>

      {/* İletişim Bilgileri */}
      <div className="glass-card p-6">
        <h3 className="text-lg font-semibold mb-4 flex items-center gap-2" style={{ color: "var(--text)" }}>
          <Smartphone className="w-5 h-5" style={{ color: "var(--primary)" }} /> İletişim Bilgileri
        </h3>
        <p className="text-xs mb-4" style={{ color: "var(--text-muted)" }}>Bu bilgiler mobil uygulamanın ana sayfasında salt okunur olarak gösterilecektir.</p>
        <div className="grid gap-3">
          {contactSettings.map((def) => (
            <div key={def.key} className="p-3 rounded-xl bg-white/[0.03]">
              <label className="text-xs font-semibold" style={{ color: "var(--text-secondary)" }}>{def.label}</label>
              <input
                type="text"
                value={settings[def.key] || def.default}
                onChange={(e) => updateSetting(def.key, e.target.value)}
                className="w-full text-sm mt-2 px-3 py-2 rounded-lg"
                style={{ background: "var(--bg-muted)", color: "var(--text)", border: "1px solid var(--border)" }}
                placeholder={def.desc}
              />
            </div>
          ))}
        </div>
      </div>

            {/* Danger Zone */}
      <div className="glass-card p-6 border border-red-500/20">
        <h3 className="text-lg font-semibold mb-4 text-red-400">⚠️ Tehlikeli Bölge</h3>
        <div className="space-y-3">
          <div className="flex items-center justify-between p-3 rounded-xl bg-red-500/5">
            <div>
              <p className="text-sm font-medium">Veritabanı Yedeği Al</p>
              <p className="text-xs text-text-muted">PostgreSQL dump dosyası indir</p>
            </div>
            <button className="text-xs px-3 py-1.5 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors">Yedek Al</button>
          </div>
          <div className="flex items-center justify-between p-3 rounded-xl bg-red-500/5">
            <div>
              <p className="text-sm font-medium">Cache Temizle</p>
              <p className="text-xs text-text-muted">Tüm önbelleği temizle ve yeniden oluştur</p>
            </div>
            <button className="text-xs px-3 py-1.5 rounded-lg bg-red-500/10 text-red-400 hover:bg-red-500/20 transition-colors">Temizle</button>
          </div>
        </div>
      </div>
    </div>
  );
}
